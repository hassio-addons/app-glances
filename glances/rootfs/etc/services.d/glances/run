#!/usr/bin/env bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Community App: Glances
# Runs Glances
# ==============================================================================
declare -a options=()
declare -a exporters=()

bashio::log.info 'Starting Glances...'

options+=(-C /etc/glances.conf)
options+=(-w)
options+=(--port 61209)
options+=(--bind 127.0.0.1)
options+=(--time "$(bashio::config 'refresh_time')")

if bashio::config.false 'process_info'; then
    options+=(--disable-process)
fi

if bashio::config.true 'influxdb.enabled'; then
    if bashio::config.equals 'influxdb.version' '2'; then
        exporters+=(influxdb2)
    else
        exporters+=(influxdb)
    fi
fi

# Glances v4 does not support --export in webserver mode (-w).
# Run a separate lightweight instance in quiet/standalone mode for exports.
if (( ${#exporters[@]} > 0 )); then
    bashio::log.info 'Starting Glances exporter...'
    glances \
        -C /etc/glances.conf \
        --quiet \
        --time "$(bashio::config 'refresh_time')" \
        --export "$(IFS=,; echo "${exporters[*]}")" &
    EXPORTER_PID=$!
    bashio::log.info "Glances exporter started (PID: ${EXPORTER_PID})"
fi

if bashio::debug; then
    options+=(--debug)
fi

# Run Glances
exec glances "${options[@]}"
