#!/usr/bin/env bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Community Add-on: Glances
# Runs Glances
# ==============================================================================
declare -a options
declare -a exporters

bashio::log.info 'Starting Glances...'

options+=(-C /etc/glances.conf)
options+=(-w)
options+=(--port 61209)
options+=(--bind 127.0.0.1)
options+=(--time "$(bashio::config 'refresh_time')")

if bashio::config.false 'process_info'; then
    options+=(--disable-process)
fi

if bashio::config.true 'influxdb.enabled'; then
    if bashio::config.equals 'influxdb.version' '2'; then
        exporters+=(influxdb2)
    else
        exporters+=(influxdb)
    fi
fi

if bashio::config.true 'mqtt.enabled'; then
    exporters+=(mqtt)
fi

if (( ${#exporters[@]} > 0 )); then
    options+=(--export "$(IFS=,; echo "${exporters[*]}")")
fi

if bashio::debug; then
    options+=(--debug)
fi

# Run Glances
exec glances "${options[@]}"
